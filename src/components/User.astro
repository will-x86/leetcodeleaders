---
const { user, daily } = Astro.props;

const [solvedRes, calRes] = await Promise.all([
    fetch(`https://leetcode-api-pied.vercel.app/user/${user}/solved`),
    fetch(`https://leetcode-api-pied.vercel.app/user/${user}/calendar`),
]);
const sub: RecentSubmissions = await solvedRes.json();
const cal: Calendar = await calRes.json();
const solvedDaily = sub.solved_slugs.includes(daily.question.titleSlug);

const calMap = cal.submissionCalendar ?? {};
const today = new Date();
today.setUTCHours(0, 0, 0, 0);
const lastWeek = Array.from({ length: 7 }, (_, i) => {
    const d = new Date(today);
    d.setUTCDate(d.getUTCDate() - 6 + i);
    const ts = Math.floor(d.getTime() / 1000).toString();
    return { date: d, count: calMap[ts] ?? 0 };
});

function level(count: number) {
    if (count === 0) return "bg-base-300";
    if (count <= 2) return "bg-primary/30";
    if (count <= 5) return "bg-primary/60";
    return "bg-primary";
}

interface RecentSubmissions {
    username: string;
    total_solved: number;
    solved_slugs: string[];
    solved: Solved[];
}

interface Solved {
    title_slug: string;
    title: string;
    timestamp: string;
}

interface Calendar {
    streak: number;
    totalActiveDays: number;
    submissionCalendar: Record<string, number>;
}
---

<div class="card bg-base-100 shadow-sm">
    <div class="card-body flex flex-row items-center justify-between">
        <div>
            <h2 class="card-title">{sub.username}</h2>
            <p>{sub.total_solved} solved</p>
            <p>
                Daily
                {solvedDaily ? " solved" : " not solved"}
            </p>
            <p>{cal.streak} day streak · {cal.totalActiveDays} active days</p>
            <div class="flex gap-1 mt-2">
                {
                    lastWeek.map((d) => (
                        <div
                            class={`w-4 h-4 rounded-sm ${level(d.count)}`}
                            title={`${d.date.toISOString().slice(0, 10)}: ${d.count}`}
                        />
                    ))
                }
            </div>
        </div>
        <img
            class=`w-30 ${solvedDaily ? "aura" : ""}`
            alt="Random cat picture from catass.com"
            src={`https://cataas.com/cat/says/${sub.username}?fontSize=20&height=200&width=200`}
        />
    </div>
</div>
